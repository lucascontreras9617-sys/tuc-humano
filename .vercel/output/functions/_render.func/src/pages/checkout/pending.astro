---
import Layout from '../../layouts/Layout.astro';
const { searchParams } = Astro.url;
const paymentId = searchParams.get('payment_id') || '';
const status = searchParams.get('status') || '';
const preferenceId = searchParams.get('preference_id') || '';
---

<Layout
  title="Pago pendiente | TUC-HUMANO"
  description="Tu pago está en proceso. Te avisaremos cuando se confirme."
  noindex={true}
>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-16">
    <div class="max-w-md w-full text-center space-y-6 animate-slide-up">

      <div class="w-24 h-24 rounded-full bg-yellow-100 flex items-center justify-center mx-auto">
        <svg class="w-12 h-12 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3" />
        </svg>
      </div>

      <div>
        <h1 class="text-3xl font-black text-gray-900">Pago en proceso</h1>
        <p class="text-gray-500 mt-3 leading-relaxed">
          Mercado Pago está procesando tu pago. En breve te notificaremos el resultado final.
        </p>
      </div>

      {paymentId && (
        <div class="bg-gray-50 rounded-xl p-4 text-sm">
          <p class="text-gray-400">Número de pago</p>
          <p class="font-mono font-bold text-gray-700 mt-1">{paymentId}</p>
        </div>
      )}

      <div class="bg-celeste-50 rounded-xl p-5 text-left space-y-3">
        <p class="font-semibold text-celeste-700">Qué puede pasar ahora</p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>• Si el pago se aprueba, te redirigiremos a la página de confirmación.</li>
          <li>• Si se cancela o rechaza, volverás a la página de pago fallido.</li>
          <li>• Si necesitas ayuda, escribinos por WhatsApp.</li>
        </ul>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/tienda" class="btn-outline flex-1">Volver a la tienda</a>
        <a
          href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '5493812311060'}?text=${encodeURIComponent('Hola! Estoy con un pago pendiente en TUC-HUMANO y necesito ayuda. Pago ID: ' + paymentId)}`}
          target="_blank"
          class="btn-primary flex-1"
        >
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</Layout>
