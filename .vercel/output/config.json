{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/create-preference\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/shipping-calculator\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/update-stock\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/checkout\\/failure\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/checkout\\/pending\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/checkout\\/success\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/producto\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/tienda\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}