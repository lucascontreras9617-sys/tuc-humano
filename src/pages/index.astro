---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import LookbookGallery from '../components/LookbookGallery.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProducts, FALLBACK_PRODUCTS } from '../lib/supabase';
import { Image, Picture } from 'astro:assets';
import igImg from '../assets/images/instagram.png';
import dedovImg from '../assets/images/foto dedo en v.webp';
import argHumanaImg from '../assets/images/libro_argentina_humana.webp';
import aritosImg from '../assets/images/aritosplaza.webp';
import frenteImg from '../assets/images/parte de frente de la remera.webp';
import atrasImg from '../assets/images/parte de atras de la remeras.webp';
import foto1Img from '../assets/images/foto 1.webp';
import lateral1Img from '../assets/images/lateral 1.webp';
import lateral2Img from '../assets/images/lateral2.webp';
import enviadoImg from '../assets/images/enviado.png';
import mpImg from '../assets/images/Mercado_Pago.svg.png';
import waImg from '../assets/images/whatsapp.png';
import { getImage } from 'astro:assets';

const optimizedAritos = await getImage({ src: aritosImg, width: 400, format: 'webp' });
const aritosCartImage = optimizedAritos.src;

let featuredProducts: any[] = [];
try {
  featuredProducts = await getProducts();
  if (!featuredProducts || featuredProducts.length === 0) {
    featuredProducts = FALLBACK_PRODUCTS;
  }
} catch (e) {
  featuredProducts = FALLBACK_PRODUCTS;
}

const heroProduct = featuredProducts[0] || null;

// Separar categorías
const remeras = featuredProducts.filter(p => p.has_sizes);
const libros = featuredProducts.filter(p => !p.has_sizes && p.slug.includes('grabois'));
const aritosYPines = featuredProducts.filter(p => !p.has_sizes && !p.slug.includes('grabois'));
---

<Layout
  title="TUC-HUMANO | Remeras Oversize desde Tucumán"
  description="Remeras oversize con diseño artístico y conciencia social. Nacidas en Tucumán, para quienes caminan cada lucha con identidad y estilo."
>

  <!-- ======== HERO SLIDER ======== -->
  <HeroSlider />

  <!-- ======== VALORES ======== -->
  <section id="valores" class="py-12 bg-[#F5F5F3]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">

      <div class="max-w-5xl mx-auto text-center relative z-10">
        <div class="space-y-10">
          
          <div class="max-w-4xl mx-auto px-8 py-8 bg-white rounded-[30px] relative shadow-sm">
            <p class="text-gray-500 text-lg md:text-2xl leading-tight font-technical text-center">
              Tienda de 
              <a href="https://www.instagram.com/patriagrande.tuc/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-black/60 hover:text-celeste-500 transition-colors font-bold group">
                <strong class="font-display uppercase tracking-tight">Argentina Humana – Patria Grande Tucumán</strong>
                <Image src={igImg} alt="Instagram" class="w-5 h-5 opacity-40 group-hover:opacity-100 transition-opacity" width={20} height={20} loading="lazy" />
              </a> 
              partido autofinanciado por su militancia. Todo lo recaudado va a acciones solidarias y al crecimiento del partido.
            </p>
          </div>

          <h2 class="section-title !-rotate-0">
            Más que una remera:<br/>
            <span class="text-celeste-500 underline decoration-8 underline-offset-[12px]">una bandera</span>
          </h2>

        </div>
      </div>
    </div>
  </section>

  <!-- ======== REMERAS (PRODUCTO ESTRELLA) ======== -->
  <section id="remeras-section" class="py-12 bg-white scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        
        <div id="remeras-grid" class="scroll-mt-20 mt-4 mb-32 relative">

          {remeras.length === 1 ? (
            <div class="max-w-7xl mx-auto">
              <!-- PREVENTA integrado arriba de la grilla -->
              <div class="bg-black text-white text-center py-5 md:py-6 mb-0 border-b-4 border-celeste-500">
                <p class="font-display text-3xl md:text-5xl lg:text-6xl uppercase tracking-tighter italic leading-none">Preventa Exclusiva</p>
                <p class="font-technical text-xs md:text-sm uppercase tracking-[0.25em] text-celeste-400 mt-2">Hasta el 20 de junio · Entrega la semana del 20 de junio</p>
              </div>

              <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 items-center mt-10">
                <!-- Banner Izquierdo -->
                <a href="/producto/remera-oversize-de-lucha" class="hidden lg:block aspect-[2/3] border-4 border-black bg-black relative group overflow-hidden shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:translate-x-2 hover:translate-y-2 hover:shadow-none transition-all duration-300">
                  <Picture src={lateral1Img} formats={['avif', 'webp']} widths={[400, 800, 1200]} sizes="(max-width: 1024px) 0px, 33vw" width={lateral1Img.width} height={lateral1Img.height} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" alt="Lateral 1" loading="lazy" quality={80} />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  <div class="absolute bottom-4 left-4 bg-celeste-500 text-white px-3 py-1 font-display text-[10px] uppercase -rotate-2 transform translate-y-10 group-hover:translate-y-0 transition-transform">Identidad</div>
                </a>

                <!-- Tarjeta de Producto (Centro) -->
                <div class="max-w-md mx-auto w-full transform lg:scale-110 relative z-10">
                  {remeras.map(p => (
                    <ProductCard
                      id={p.id}
                      name={p.name}
                      slug="remera-oversize-de-lucha"
                      price={p.price}
                      old_price={p.old_price}
                      image_url={p.image_url}
                      image_back_url="/images/lateral2.webp"
                      stock_s={p.stock_s}
                      stock_m={p.stock_m}
                      stock_l={p.stock_l}
                      stock_xl={p.stock_xl}
                      stock_unico={p.stock_unico}
                      has_sizes={p.has_sizes}
                      is_featured={true}
                    />
                  ))}
                </div>

                <!-- Banner Derecho -->
                <a href="/producto/remera-oversize-de-lucha" class="hidden lg:block aspect-[2/3] border-4 border-black bg-black relative group overflow-hidden shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:translate-x-2 hover:translate-y-2 hover:shadow-none transition-all duration-300">
                  <Picture src={atrasImg} formats={['avif', 'webp']} widths={[400, 800, 1200]} sizes="(max-width: 1024px) 0px, 33vw" width={atrasImg.width} height={atrasImg.height} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" alt="Hombre de espalda" loading="lazy" quality={80} />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  <div class="absolute bottom-4 right-4 bg-celeste-500 text-white px-3 py-1 font-display text-[10px] uppercase rotate-2 transform translate-y-10 group-hover:translate-y-0 transition-transform">Resistencia</div>
                </a>
              </div>
            </div>
          ) : (
            <div>
              <!-- PREVENTA integrado arriba de la grilla -->
              <div class="bg-black text-white text-center py-5 md:py-6 mb-8 border-b-4 border-celeste-500">
                <p class="font-display text-3xl md:text-5xl lg:text-6xl uppercase tracking-tighter italic leading-none">Preventa Exclusiva</p>
                <p class="font-technical text-xs md:text-sm uppercase tracking-[0.25em] text-celeste-400 mt-2">Hasta el 20 de junio · Entrega la semana del 20 de junio</p>
              </div>
              <div class={`grid gap-5 scroll-mt-20 ${remeras.length === 2 ? 'grid-cols-1 sm:grid-cols-2 max-w-3xl mx-auto' : remeras.length === 3 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'}`}>
                {remeras.map(p => (
                  <ProductCard
                    id={p.id}
                    name={p.name}
                    slug="remera-oversize-de-lucha"
                    price={p.price}
                    old_price={p.old_price}
                    image_url={p.image_url}
                    image_back_url={p.image_back_url}
                    stock_s={p.stock_s}
                    stock_m={p.stock_m}
                    stock_l={p.stock_l}
                    stock_xl={p.stock_xl}
                    stock_unico={p.stock_unico}
                    has_sizes={p.has_sizes}
                  />
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- 2) Galería Single + Texto (Explicación) -->
        <div class="mt-32">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 reveal-text max-w-5xl mx-auto items-stretch">
            
            <!-- BLOQUE 1: Texto (Marco cuadrado ajustado a la foto) -->
            <div class="aspect-square bg-black text-white p-10 md:p-14 border-l-[20px] border-celeste-500 shadow-xl flex flex-col justify-center text-center">
              <div class="space-y-6 md:space-y-8">
                <p class="text-xl md:text-3xl lg:text-4xl font-display uppercase tracking-[-0.04em] leading-[0.95] italic">
                  No son solo prendas, son una declaración de identidad y valores.
                </p>
                <div class="h-1.5 md:h-2 w-20 md:w-24 bg-celeste-500 mx-auto"></div>
                <p class="text-sm md:text-lg lg:text-xl font-display uppercase tracking-[-0.02em] leading-tight italic text-gray-400">
                  Cada diseño rinde homenaje a los símbolos de <span class="text-celeste-400">la lucha popular</span> y a quienes soñaron con una <span class="text-celeste-500 underline decoration-4 underline-offset-8">Argentina más justa, libre y soberana.</span>
                </p>
              </div>
              <div class="mt-8 md:mt-12">
                <p class="text-[10px] md:text-xs lg:text-sm uppercase tracking-widest text-gray-500 font-technical">Algodón premium · Fit oversize · Arte propio</p>
              </div>
            </div>

            <!-- BLOQUE 2: Foto Única (Dedo en V) -->
            <a href="/producto/remera-oversize-de-lucha" class="aspect-square group relative overflow-hidden border-8 border-black shadow-lg bg-black block">
              <Picture 
                src={dedovImg} 
                formats={['avif', 'webp']}
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 600px"
                width={dedovImg.width}
                height={dedovImg.height}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                alt="Foto dedo en v"
                loading="lazy"
                quality={80}
              />
              <div class="absolute bottom-6 left-6 bg-celeste-50 text-celeste-600 px-4 py-2 font-display text-xs uppercase font-bold shadow-md">Identidad y Resistencia</div>
            </a>

          </div>
        </div>

        <!-- Recuadros de Valor -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mt-32">
          {[
            { title: 'Algodón premium', desc: 'Suave, resistente y confortable' },
            { title: 'Arte propio', desc: 'Diseños únicos con mensaje' },
            { title: 'Fit oversize', desc: 'Para todos los cuerpos' },
            { title: 'Militante', desc: 'Cada remera es una bandera' },
          ].map(item => (
            <div class="bg-white rounded-xl p-6 hover:bg-celeste-50 transition-all duration-300 border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:-translate-y-1">
              <p class="font-display uppercase tracking-tight text-gray-900 text-xl leading-tight">{item.title}</p>
              <p class="text-gray-500 text-xs mt-2 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ======== LIBROS ======== -->
  {libros.length > 0 && (
    <section id="libros" class="py-24 bg-[#F5F5F3] scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-14 text-center">
          <h2 class="section-title">Libros</h2>
          <p class="text-base md:text-lg text-gray-800 font-technical font-semibold max-w-2xl mx-auto my-4 uppercase tracking-wider">
            Herramientas para el pensamiento crítico y la acción popular.
          </p>
        </div>

        <div class={`grid gap-6 justify-center mx-auto ${
          libros.length === 1 ? 'max-w-sm grid-cols-1' :
          libros.length === 2 ? 'max-w-4xl grid-cols-1 sm:grid-cols-2' :
          libros.length === 3 ? 'max-w-5xl grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' :
          'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'
        }`}>
          {libros.map(p => (
            <ProductCard
              id={p.id}
              name={p.name}
              slug={p.slug}
              price={p.price}
              old_price={p.old_price}
              image_url={p.image_url}
              image_back_url={p.image_back_url}
              stock_s={p.stock_s}
              stock_m={p.stock_m}
              stock_l={p.stock_l}
              stock_xl={p.stock_xl}
              stock_unico={p.stock_unico}
              has_sizes={p.has_sizes}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ======== ARITOS Y PINES ======== -->
  {aritosYPines.length > 0 && (
    <section id="aritos-y-pines" class="py-24 bg-white scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-14 text-center">
          <h2 class="section-title">Aritos y Pines</h2>
          <p class="text-base md:text-lg text-gray-800 font-technical font-semibold max-w-2xl mx-auto my-4 uppercase tracking-wider">
            Accesorios con identidad y resistencia.
          </p>
        </div>

        <div class={`grid gap-6 justify-center mx-auto ${
          aritosYPines.length === 1 ? 'max-w-sm grid-cols-1' :
          aritosYPines.length === 2 ? 'max-w-4xl grid-cols-1 sm:grid-cols-2' :
          aritosYPines.length === 3 ? 'max-w-5xl grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' :
          'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'
        }`}>
          <!-- Custom Oferta Card para Aritos -->
          <article class="product-card group relative flex flex-col h-full aritos-card" data-product-id="prod-5">
            <a href="/producto/aritos-alpaca-con-pasador-de-plata" class="block">
              <!-- Image -->
              <div class="relative overflow-hidden bg-black border-b-4 border-black aspect-[3/4]">
                <Picture 
                  src={aritosImg} 
                  formats={['avif', 'webp']}
                  widths={[400, 800]}
                  sizes="(max-width: 640px) 100vw, 400px"
                  width={600}
                  height={800}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  alt="aritos de alpaca con pasador de plata"
                  loading="lazy"
                  quality={80}
                />
              </div>

              <!-- Info -->
              <div class="p-4 text-center">
                <h3 class="font-semibold text-gray-900 leading-tight mb-1 text-sm">aritos de alpaca con pasador de plata</h3>
                <div class="flex items-center justify-center gap-3 mt-1">
                  <span class="text-celeste-600 font-bold text-sm">Par <strong class="text-lg">$23.000</strong></span>
                  <span class="text-gray-300">|</span>
                  <span class="text-gray-600 font-bold text-sm">Unit. <strong class="text-lg">$15.000</strong></span>
                </div>
              </div>
            </a>
            
            <div class="px-4 pb-4 flex flex-col gap-3 relative z-20 mt-auto">
              <div class="flex gap-2 mt-2">
                <button 
                  class="add-aritos-btn bg-celeste-500 text-white hover:bg-black font-bold py-2.5 px-1 text-center w-full transition-colors text-xs uppercase tracking-wider flex items-center justify-center gap-1 active:scale-95"
                  data-qty="2"
                  data-product={JSON.stringify({ id: 'prod-5', name: 'aritos de alpaca con pasador de plata', price: 15000, image_url: aritosCartImage, has_sizes: false })}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                  Par
                </button>
                <button 
                  class="add-aritos-btn bg-black text-white hover:bg-celeste-500 font-bold py-2.5 px-1 text-center w-full transition-colors text-xs uppercase tracking-wider flex items-center justify-center gap-1 active:scale-95"
                  data-qty="1"
                  data-product={JSON.stringify({ id: 'prod-5', name: 'aritos de alpaca con pasador de plata', price: 15000, image_url: aritosCartImage, has_sizes: false })}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                  Unidad
                </button>
              </div>
            </div>
          </article>

          {aritosYPines.filter(p => !p.slug.includes('arito')).map(p => (
            <ProductCard
              id={p.id}
              name={p.name}
              slug={p.slug}
              price={p.price}
              old_price={p.old_price}
              image_url={p.image_url}
              image_back_url={p.image_back_url}
              stock_s={p.stock_s}
              stock_m={p.stock_m}
              stock_l={p.stock_l}
              stock_xl={p.stock_xl}
              stock_unico={p.stock_unico}
              has_sizes={p.has_sizes}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ======== SELECCIÓN DE CATEGORÍAS ======== -->
  <section class="py-16 bg-[#F5F5F3]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Opción Remeras -->
        <a href="#remeras-section" class="md:col-span-1 group relative aspect-[16/9] md:aspect-auto md:h-[380px] overflow-hidden rounded-3xl border-8 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300">
          <Picture 
            src={dedovImg} 
            formats={['avif', 'webp']}
            widths={[400, 800, 1200, 1600]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 900px"
            width={dedovImg.width}
            height={dedovImg.height}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            alt="Sección Remeras"
            loading="lazy"
            quality={80}
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors flex items-center justify-center">
            <div class="text-center">
              <h3 class="text-white text-5xl md:text-7xl font-black italic tracking-tighter uppercase">Remeras</h3>
              <span class="inline-block mt-4 bg-celeste-500 text-white px-6 py-2 font-display text-sm uppercase">Ver colección</span>
            </div>
          </div>
        </a>

        <!-- Opción Libros -->
        <a href="#libros" class="group relative aspect-[16/9] md:aspect-auto md:h-[380px] overflow-hidden rounded-3xl border-8 border-black shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300">
          <Picture 
            src={argHumanaImg} 
            formats={['avif', 'webp']}
            widths={[400, 800, 1200]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 450px"
            width={argHumanaImg.width}
            height={argHumanaImg.height}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            alt="Sección Libros"
            loading="lazy"
            quality={80}
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors flex items-center justify-center">
            <div class="text-center">
              <h3 class="text-white text-5xl md:text-7xl font-black italic tracking-tighter uppercase">Libros</h3>
              <span class="inline-block mt-4 bg-white text-black px-6 py-2 font-display text-sm uppercase">Cultura y lucha</span>
            </div>
          </div>
        </a>

        <!-- Opción Aritos y Pines -->
        <a href="#aritos-y-pines" class="group relative aspect-[16/9] md:aspect-auto md:h-[380px] overflow-hidden rounded-3xl border-8 border-black shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300">
          <Picture 
            src={aritosImg} 
            formats={['avif', 'webp']}
            widths={[400, 800, 1200]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 450px"
            width={500}
            height={500}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            alt="Sección Aritos y Pines"
            loading="lazy"
            quality={80}
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors flex items-center justify-center">
            <div class="text-center">
              <h3 class="text-white text-4xl md:text-5xl lg:text-6xl font-black italic tracking-tighter uppercase">Aritos y<br/>Pines</h3>
              <span class="inline-block mt-4 bg-white text-black px-6 py-2 font-display text-sm uppercase">Accesorios</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== LOOKBOOK ======== -->
  <LookbookGallery
    images={[
      { src: '/src/assets/images/lookbook1.jpg', alt: 'TUC-HUMANO campaña' }
    ]}
  />

  <!-- ======== ENVÍO BANNER ======== -->
  <section class="py-16 bg-[#F0EFED]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-black text-center">
          <!-- Envío -->
          <div class="flex flex-col items-center gap-6 group">
            <div class="h-20 w-auto flex items-center justify-center p-2">
              <Image src={enviadoImg} alt="Envío" class="h-full w-auto object-contain transition-all duration-300" width={512} height={512} loading="lazy" quality={90} />
            </div>
            <div class="text-center">
