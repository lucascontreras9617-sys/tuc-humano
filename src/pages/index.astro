---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import LookbookGallery from '../components/LookbookGallery.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProducts, FALLBACK_PRODUCTS } from '../lib/supabase';

let featuredProducts: any[] = [];
try {
  featuredProducts = await getProducts();
  if (!featuredProducts || featuredProducts.length === 0) {
    featuredProducts = FALLBACK_PRODUCTS;
  }
} catch (e) {
  featuredProducts = FALLBACK_PRODUCTS;
}

const heroProduct = featuredProducts[0] || null;

// Separar libros de remeras (has_sizes indica si es textil o producto unico)
const remeras = featuredProducts.filter(p => p.has_sizes);
const librosYOtros = featuredProducts.filter(p => !p.has_sizes);
---

<Layout
  title="TUC-HUMANO | Remeras Oversize desde Tucumán"
  description="Remeras oversize con diseño artístico y conciencia social. Nacidas en Tucumán, para quienes caminan cada lucha con identidad y estilo."
>

  <!-- ======== HERO SLIDER ======== -->
  <HeroSlider />

  <!-- ======== VALORES ======== -->
  <section id="valores" class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-4xl mx-auto text-center">
        <div class="space-y-6">
          <span class="inline-block bg-celeste-50 text-celeste-600 text-xs font-bold px-6 py-2 rounded-full uppercase tracking-widest">
            Nuestros valores
          </span>
          <h2 class="section-title !-rotate-0">
            Más que una remera:<br/>
            <span class="text-celeste-500 underline decoration-8 underline-offset-[12px]">una bandera</span>
          </h2>

          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-4">
            {[
              { title: 'Algodón premium', desc: 'Suave, resistente y confortable' },
              { title: 'Arte propio', desc: 'Diseños únicos con mensaje' },
              { title: 'Fit oversize', desc: 'Para todos los cuerpos' },
              { title: 'Militante', desc: 'Cada remera es una bandera' },
            ].map(item => (
              <div class="bg-white rounded-xl p-5 hover:bg-celeste-50 transition-all duration-300 border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:-translate-y-1">
                <p class="font-display uppercase tracking-tight text-gray-900 text-lg leading-tight">{item.title}</p>
                <p class="text-gray-500 text-xs mt-1 leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== SELECCIÓN DE CATEGORÍAS ======== -->
  <section class="py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Opción Remeras (2/3 del ancho) -->
        <a href="#remeras-section" class="md:col-span-2 group relative aspect-[16/9] md:aspect-auto md:h-[380px] overflow-hidden rounded-3xl border-8 border-black shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300">
          <img 
            src="/images/parte de frente de la remera.webp" 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            alt="Sección Remeras"
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors flex items-center justify-center">
            <div class="text-center">
              <h3 class="text-white text-5xl md:text-7xl font-black italic tracking-tighter uppercase">Remeras</h3>
              <span class="inline-block mt-4 bg-celeste-500 text-white px-6 py-2 font-display text-sm uppercase">Ver colección</span>
            </div>
          </div>
        </a>

        <!-- Opción Libros (1/3 del ancho) -->
        <a href="#libros" class="group relative aspect-[16/9] md:aspect-auto md:h-[380px] overflow-hidden rounded-3xl border-8 border-black shadow-[12px_12px_0px_0px_rgba(0,174,239,1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300">
          <img 
            src="/images/libro_argentina_humana.webp" 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            alt="Sección Libros"
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors flex items-center justify-center">
            <div class="text-center">
              <h3 class="text-white text-5xl md:text-7xl font-black italic tracking-tighter uppercase">Libros</h3>
              <span class="inline-block mt-4 bg-white text-black px-6 py-2 font-display text-sm uppercase">Cultura y lucha</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ======== REMERAS (PRODUCTO ESTRELLA) ======== -->
  <section id="remeras-section" class="py-10 bg-gray-50 border-y-8 border-black scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <h2 class="section-title">Nuestras Remeras</h2>

        <!-- Layout: Texto recortado + Galería Dúo lado a lado -->
        <div class="mt-6 grid grid-cols-1 lg:grid-cols-5 gap-6 reveal-text">
          <!-- Bloque de texto compacto (2/5) -->
          <div class="lg:col-span-2 bg-black text-white p-6 md:p-8 border-l-[16px] border-celeste-500 shadow-[20px_20px_0px_0px_rgba(0,174,239,0.25)] flex flex-col justify-between">
            <div class="space-y-6">
              <p class="text-xl md:text-2xl font-display uppercase tracking-[-0.04em] leading-[0.9] italic">
                No son solo prendas, son una declaración de identidad y valores.
              </p>
              <div class="h-1 w-24 bg-celeste-500"></div>
              <p class="text-base md:text-lg font-display uppercase tracking-[-0.02em] leading-tight italic text-gray-400">
                Cada diseño rinde homenaje a los símbolos de <span class="text-celeste-400">la lucha popular</span> y a quienes soñaron con una <span class="text-celeste-500 underline decoration-4 underline-offset-8">Argentina más justa, libre y soberana.</span>
              </p>
            </div>
            <div class="mt-6 space-y-3">
              <p class="text-xs uppercase tracking-widest text-gray-500 font-technical">Algodón premium · Fit oversize · Arte propio</p>
              <a href="#remeras-grid" class="btn-primary text-sm py-3 px-6 w-full text-center">Ver todas las remeras</a>
            </div>
          </div>

          <!-- Galería Dúo (3/5) -->
          <div class="lg:col-span-3 grid grid-cols-2 gap-4 reveal-text-delay">
            <!-- Frente -->
            <div class="group relative aspect-[4/5] overflow-hidden border-8 border-black shadow-lg bg-black">
              <img 
                src="/images/parte de frente de la remera.webp" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                alt="Vista Frontal" 
              />
              <div class="absolute bottom-4 left-4 bg-celeste-500 text-white px-4 py-1 font-display text-xs uppercase -rotate-2">Identidad</div>
            </div>
            <!-- Espalda -->
            <div class="group relative aspect-[4/5] overflow-hidden border-8 border-black shadow-lg bg-black">
              <img 
                src="/images/parte de atras de la remeras.webp" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                alt="Vista Dorsal" 
              />
              <div class="absolute bottom-4 right-4 bg-celeste-500 text-white px-4 py-1 font-display text-xs uppercase rotate-2">Resistencia</div>
            </div>
          </div>
        </div>

        <!-- Frase de refuerzo entre galería y productos -->
        <div class="mt-6 flex items-center gap-4">
          <div class="h-1 flex-1 bg-black"></div>
          <p class="font-display uppercase tracking-tighter text-lg md:text-2xl italic text-gray-900 whitespace-nowrap">Suavidad, durabilidad y confort — para todos los cuerpos</p>
          <div class="h-1 flex-1 bg-black"></div>
        </div>
      </div>

      <div id="remeras-grid" class={`grid gap-5 scroll-mt-20 ${remeras.length === 1 ? 'grid-cols-1 max-w-md mx-auto sm:max-w-lg' : remeras.length === 2 ? 'grid-cols-1 sm:grid-cols-2 max-w-3xl mx-auto' : remeras.length === 3 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'}`}>
        {remeras.map(p => (
          <ProductCard
            id={p.id}
            name={p.name}
            slug={p.slug}
            price={p.price}
            old_price={p.old_price}
            image_url={p.image_url}
            image_back_url={p.image_back_url}
            stock_s={p.stock_s}
            stock_m={p.stock_m}
            stock_l={p.stock_l}
            stock_xl={p.stock_xl}
            stock_unico={p.stock_unico}
            has_sizes={p.has_sizes}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ======== LIBROS Y OTROS ======== -->
  {librosYOtros.length > 0 && (
    <section id="libros" class="py-14 bg-white scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Featured Book Header (Argentina Humana) - más compacto -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center mb-12 bg-gray-50 p-6 md:p-10 border-8 border-black shadow-[20px_20px_0px_0px_rgba(0,174,239,0.2)]">
          <div class="relative group">
            <img 
              src="/images/libro_argentina_humana.webp" 
              alt="Libro Argentina Humana" 
              class="w-full h-auto rounded-lg shadow-2xl border-4 border-black group-hover:-rotate-2 transition-transform duration-500"
            />
            <div class="absolute -top-4 -right-4 bg-celeste-500 text-white w-20 h-20 rounded-full flex items-center justify-center font-black text-lg rotate-12 border-4 border-black shadow-lg">
              INFO
            </div>
          </div>
          <div class="space-y-4">
            <span class="inline-block bg-black text-white px-4 py-1 font-display text-sm uppercase tracking-widest">Destacado</span>
            <h2 class="text-4xl md:text-5xl font-black italic leading-[0.9] text-black">ARGENTINA HUMANA</h2>
            <div class="h-2 w-24 bg-celeste-500 font-bold"></div>
            <p class="text-base md:text-lg text-gray-800 leading-relaxed font-sans italic">
              Juan Grabois nos invita a explorar una visión transformadora de la justicia social. Un enfoque contracultural que desafía las estructuras tradicionales, proponiendo un modelo más inclusivo y humano.
            </p>
            <div class="pt-2">
              <a href="/producto/argentina-humana-grabois" class="btn-primary">
                Ver detalles del libro
              </a>
            </div>
          </div>
        </div>

        <div class="mb-8 text-right">
          <h2 class="section-title">Más títulos</h2>
          <p class="text-lg text-gray-800 font-sans font-semibold max-w-2xl border-r-4 border-black pr-4 my-4 ml-auto">
            Herramientas para el pensamiento crítico y la acción popular.
          </p>
        </div>

        <div class={`grid gap-5 ${librosYOtros.length <= 3 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'}`}>
          {librosYOtros.map(p => (
            <ProductCard
              id={p.id}
              name={p.name}
              slug={p.slug}
              price={p.price}
              old_price={p.old_price}
              image_url={p.image_url}
              image_back_url={p.image_back_url}
              stock_s={p.stock_s}
              stock_m={p.stock_m}
              stock_l={p.stock_l}
              stock_xl={p.stock_xl}
              stock_unico={p.stock_unico}
              has_sizes={p.has_sizes}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ======== LOOKBOOK ======== -->
  <LookbookGallery
    images={[
      { src: '/images/parte de frente de la remera.webp', alt: 'TUC-HUMANO campaña - frente' },
      { src: '/images/parte de atras de la remeras.webp', alt: 'TUC-HUMANO campaña - espalda' },
      { src: '/images/foto 1.webp', alt: 'TUC-HUMANO - detalle' },
      { src: '/images/foto 2.webp', alt: 'TUC-HUMANO - estilo' },
    ]}
  />

  <!-- ======== ENVÍO BANNER ======== -->
  <section class="py-16 bg-celeste-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-white text-center">
          <!-- Envío -->
          <div class="flex flex-col items-center gap-6 group">
            <div class="h-20 w-auto flex items-center justify-center p-2">
              <img src="/images/enviado.png" alt="Envío" class="h-full w-auto object-contain brightness-0 invert group-hover:brightness-100 group-hover:invert-0 transition-all duration-300" />
            </div>
            <div class="text-center">
              <p class="font-display text-2xl uppercase tracking-tighter leading-none mb-2">Envíos Nacionales</p>
              <p class="text-celeste-100 text-xs font-technical uppercase tracking-widest opacity-80">Logística Andreani</p>
            </div>
          </div>
          
          <!-- Pago -->
          <div class="flex flex-col items-center gap-6 group">
            <div class="h-20 w-auto flex items-center justify-center p-2">
              <img src="/images/Mercado_Pago.svg.png" alt="Mercado Pago" class="h-full w-auto object-contain brightness-0 invert group-hover:brightness-100 group-hover:invert-0 transition-all duration-300" />
            </div>
            <div class="text-center">
              <p class="font-display text-2xl uppercase tracking-tighter leading-none mb-2">Pago Garantizado</p>
              <p class="text-celeste-100 text-xs font-technical uppercase tracking-widest opacity-80">Mercado Pago Protegido</p>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex flex-col items-center gap-6 group">
            <div class="h-20 w-auto flex items-center justify-center p-2">
              <img src="/images/whatsapp.png" alt="WhatsApp" class="h-full w-auto object-contain brightness-0 invert group-hover:brightness-100 group-hover:invert-0 transition-all duration-300" />
            </div>
            <div class="text-center">
              <p class="font-display text-2xl uppercase tracking-tighter leading-none mb-2">Consultas Directas</p>
              <p class="text-celeste-100 text-xs font-technical uppercase tracking-widest opacity-80">WhatsApp 24/7</p>
            </div>
          </div>
      </div>
    </div>
  </section>

</Layout>
