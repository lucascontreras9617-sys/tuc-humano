---
import '../styles/global.css';
import '@fontsource/anton';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CartDrawer from '../components/CartDrawer.astro';
import { ViewTransitions } from 'astro:transitions';

import logoWebp from '../assets/images/logo_y_marca_de_la_pagina.webp';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'TUC-HUMANO | Remeras Oversize desde Tucumán',
  description = 'Remeras oversize con diseño artístico y conciencia social. Nacidas en Tucumán, para quienes caminan cada lucha con identidad y estilo.',
  image = logoWebp.src,
  noindex = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://tuc-humano.com.ar';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const titlePart = title.split('|')[0].trim();
const pageTitle = title.includes('Indumentaria Peronista') 
  ? title 
  : `${titlePart} | Tuc-Humano - Indumentaria Peronista y Estilo Federal desde Tucumán`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <ViewTransitions />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:site_name" content="TUC-HUMANO" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://jenbskrxpktziiajrbpt.supabase.co" />

    <!-- Critical CSS: font-display swap for all @fontsource fonts -->
    <style is:inline>
      @font-face { font-family: 'Anton'; font-display: swap; }
      @font-face { font-family: 'Space Grotesk Variable'; font-display: swap; }
      @font-face { font-family: 'Inter Variable'; font-display: swap; }
      /* Prevent layout shift on header */
      #main-header { min-height: 64px; }
      /* Prevent CLS on hero */
      .hero-slide img, .hero-slide picture { width: 100%; height: 100%; object-fit: cover; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <CartDrawer />
  </body>
</html>
