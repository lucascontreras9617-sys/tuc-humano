---
// Header con logo, nav y carrito
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const isTienda = pathname.startsWith('/tienda');
---

<header id="main-header" class="sticky top-0 z-50 bg-white/90 backdrop-blur-md transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 hover:opacity-80 transition-opacity">
        <img
          src="/images/logo_y_marca_de_la_pagina.webp"
          alt="TUC-HUMANO"
          class="h-12 w-auto"
        />
      </a>

      <!-- Nav Desktop -->
      <nav class="hidden md:flex items-center gap-8 h-full">
        <a href="/" class="nav-link font-technical uppercase tracking-widest text-xs font-bold text-black hover:text-celeste-600 hover:border-black transition-colors h-16 flex items-center border-b-4 border-transparent">INICIO</a>
        <a href="/tienda" class="nav-link font-technical uppercase tracking-widest text-xs font-bold text-black hover:text-celeste-600 hover:border-black transition-colors h-16 flex items-center border-b-4 border-transparent">TIENDA</a>
        <a href="/#libros" class="nav-link font-technical uppercase tracking-widest text-xs font-bold text-black hover:text-celeste-600 hover:border-black transition-colors h-16 flex items-center border-b-4 border-transparent">LIBROS</a>
        <a href="/#lookbook" class="nav-link font-technical uppercase tracking-widest text-xs font-bold text-black hover:text-celeste-600 hover:border-black transition-colors h-16 flex items-center border-b-4 border-transparent">LA REMERA EN ACCIÓN</a>
        <a href="/#valores" class="nav-link font-technical uppercase tracking-widest text-xs font-bold text-black hover:text-celeste-600 hover:border-black transition-colors h-16 flex items-center border-b-4 border-transparent">NOSOTROS</a>
      </nav>

      <!-- Carrito + Menu mobile -->
      <div class="flex items-center gap-2">
        <!-- Cart Button -->
        <button
          id="cart-toggle-btn"
          class="relative p-2 border-2 border-transparent hover:border-black hover:bg-black hover:text-white text-black transition-colors"
          aria-label="Abrir carrito"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span
            id="cart-count-badge"
            class="absolute -top-2 -right-2 bg-celeste-500 text-white text-xs font-bold font-technical border-2 border-black rounded-full h-6 w-6 flex items-center justify-center hidden"
          >0</span>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 border-2 border-transparent hover:border-black hover:bg-black hover:text-white text-black transition-colors"
          aria-label="Abrir menú"
        >
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 border-t-4 border-black mt-2 pt-4">
      <nav class="flex flex-col gap-2">
        <a href="/" class="font-technical uppercase tracking-widest text-sm font-bold text-black hover:text-celeste-600 hover:bg-gray-50 hover:border-black transition-colors px-4 py-3 border-l-4 border-transparent">INICIO</a>
        <a href="/tienda" class="font-technical uppercase tracking-widest text-sm font-bold text-black hover:text-celeste-600 hover:bg-gray-50 hover:border-black transition-colors px-4 py-3 border-l-4 border-transparent">TIENDA</a>
        <a href="/#libros" class="font-technical uppercase tracking-widest text-sm font-bold text-black hover:text-celeste-600 hover:bg-gray-50 hover:border-black transition-colors px-4 py-3 border-l-4 border-transparent">LIBROS</a>
        <a href="/#lookbook" class="font-technical uppercase tracking-widest text-sm font-bold text-black hover:text-celeste-600 hover:bg-gray-50 hover:border-black transition-colors px-4 py-3 border-l-4 border-transparent">LA REMERA EN ACCIÓN</a>
        <a href="/#valores" class="font-technical uppercase tracking-widest text-sm font-bold text-black hover:text-celeste-600 hover:bg-gray-50 hover:border-black transition-colors px-4 py-3 border-l-4 border-transparent">NOSOTROS</a>
      </nav>
    </div>

  </div>
</header>

<script>
  import { cartCount, cartOpen } from '../lib/cart';

  document.addEventListener('astro:page-load', () => {
    // Cart counter badge
    cartCount.subscribe((count) => {
      const badge = document.getElementById('cart-count-badge');
      if (badge) {
        badge.textContent = String(count);
        badge.classList.toggle('hidden', count === 0);
      }
    });

    // Open cart on button click
    document.getElementById('cart-toggle-btn')?.addEventListener('click', () => {
      cartOpen.set(true);
    });

    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuBtn?.addEventListener('click', () => {
      const isOpen = !mobileMenu?.classList.contains('hidden');
      mobileMenu?.classList.toggle('hidden');
      menuIcon?.classList.toggle('hidden', !isOpen ? true : false);
      closeIcon?.classList.toggle('hidden', !isOpen ? false : true);
    });

    // Auto-close mobile menu on link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });

    // Shadow on scroll
    window.addEventListener('scroll', () => {
      const header = document.getElementById('main-header');
      if (header) {
        header.classList.toggle('shadow-md', window.scrollY > 10);
      }
    });
  });
</script>
