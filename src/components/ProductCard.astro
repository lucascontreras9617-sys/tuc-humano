---
import { Image, getImage, Picture } from 'astro:assets';
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}');

interface Props {
  id: string;
  name: string;
  slug: string;
  price: number;
  old_price?: number | null;
  image_url: string;
  image_back_url?: string | null;
  stock_s?: number;
  stock_m?: number;
  stock_l?: number;
  stock_xl?: number;
  stock_unico?: number;
  has_sizes?: boolean;
  is_featured?: boolean;
  color_variants?: { name: string, image_url: string, image_back_url?: string }[] | null;
  gallery_images?: string[] | null;
}

const { id, name, slug, price, old_price, image_url, image_back_url, stock_s = 0, stock_m = 0, stock_l = 0, stock_xl = 0, stock_unico = 0, has_sizes = true, is_featured = false, color_variants = null, gallery_images = null } = Astro.props;
const hasStock = has_sizes ? (stock_s > 0 || stock_m > 0 || stock_l > 0 || stock_xl > 0) : stock_unico > 0;
const useGallerySlideshow = gallery_images && gallery_images.length > 2;

const formatPrice = (p: number) => new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
}).format(p);

const formatted = formatPrice(price);
const formattedOld = old_price ? formatPrice(old_price) : null;
const discountPercent = old_price ? Math.round(((old_price - price) / old_price) * 100) : 0;

const imagePath1 = `/src/assets${image_url}`;
const imagePath2 = image_back_url ? `/src/assets${image_back_url}` : null;

const img1 = imagesGlob[imagePath1] ? (await imagesGlob[imagePath1]()).default : null;
const img2 = imagePath2 && imagesGlob[imagePath2] ? (await imagesGlob[imagePath2]()).default : null;

let optimizedImageUrlForCart = image_url;
if (imagesGlob[imagePath1]) {
  const optimized = await getImage({ src: imagesGlob[imagePath1]() });
  optimizedImageUrlForCart = optimized.src;
}
---

<article class={`product-card group relative ${is_featured ? 'shadow-[0_20px_50px_rgba(0,174,239,0.3)] border-4 border-celeste-500 rounded-2xl overflow-hidden bg-white z-20' : ''}`} data-product-id={id}>
  <a href={`/producto/${slug}`} class="block">
    <!-- Image -->
    <div class={`relative overflow-hidden bg-white border-b-4 border-black ${is_featured ? 'aspect-[2/3]' : 'aspect-[3/4]'}`}>
      <!-- Foto Principal -->
      {useGallerySlideshow ? (
        /* Multi-image gallery slideshow */
        gallery_images.map((imgSrc, idx) => (
          <img
            src={imgSrc}
            alt={`${name} - Vista ${idx + 1}`}
            class={`gallery-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${idx === 0 ? 'opacity-100' : 'opacity-0'}`}
            data-slide-index={idx}
            loading={idx === 0 ? 'eager' : 'lazy'}
          />
        ))
      ) : (
        <>
          {img1 ? (
            <Picture
              src={img1}
              alt={name}
              formats={['avif', 'webp']}
              widths={[400, 800, 1200, 1600]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px"
              width={img1.width}
              height={img1.height}
              class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${image_back_url ? 'auto-fade-out' : ''}`}
              loading="lazy"
              quality={80}
            />
          ) : (
            <Picture
              src={image_url}
              alt={name}
              formats={['avif', 'webp']}
              widths={[400, 800, 1200, 1600]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px"
              width={600}
              height={800}
              class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${image_back_url ? 'auto-fade-out' : ''}`}
              loading="lazy"
              quality={80}
            />
          )}
          
          {/* Foto Secundaria (Solo si existe) */}
          {img2 ? (
            <Picture
              src={img2}
              alt={`${name} - Vista alternativa`}
              formats={['avif', 'webp']}
              widths={[400, 800, 1200, 1600]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px"
              width={img2.width}
              height={img2.height}
              class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 auto-fade-in"
              loading="lazy"
              quality={80}
            />
          ) : image_back_url ? (
            <Picture
              src={image_back_url}
              alt={`${name} - Vista alternativa`}
              formats={['avif', 'webp']}
              widths={[400, 800, 1200, 1600]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px"
              width={600}
              height={800}
              class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 auto-fade-in"
              loading="lazy"
              quality={80}
            />
          ) : null}
        </>
      )}
      <!-- Overlay img for color-swap (uses public/images paths, no Astro hash) -->
      {color_variants && color_variants.length > 0 && (
        <img
          class="card-color-overlay absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 z-10 bg-white"
          src=""
          alt={name}
          aria-hidden="true"
        />
      )}

      {!hasStock && (
        <div class="absolute inset-0 bg-white/70 flex items-center justify-center z-20">
          <span class="bg-gray-900 text-white text-xs font-semibold px-4 py-2 rounded-full">Sin stock</span>
        </div>
      )}
      
      <!-- Badges -->
      <div class="absolute top-3 left-3 flex flex-col gap-2 z-20">
        {has_sizes && (
          <span class="bg-celeste-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm">
            OVERSIZE
          </span>
        )}
        {discountPercent > 0 && (
          <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm w-fit">
            -{discountPercent}%
          </span>
        )}
      </div>
    </div>

    <!-- Info -->
    <div class={`p-4 text-center ${is_featured ? 'py-2' : ''}`}>
      <h3 class={`font-semibold text-gray-900 leading-tight mb-1 ${is_featured ? 'text-lg' : 'text-sm'}`}>{name}</h3>
      <div class="flex items-center justify-center gap-2 mt-1">
        <p class={`text-celeste-600 font-bold ${is_featured ? 'text-2xl' : 'text-lg'}`}>{formatted}</p>
        {formattedOld && (
          <p class="text-gray-400 text-sm line-through">{formattedOld}</p>
        )}
      </div>
    </div>
  </a>

  <!-- Quick Add (shows on hover) -->
  {hasStock && (
    <div class={`px-4 pb-4 flex flex-col relative z-20 ${is_featured ? 'gap-2' : 'gap-3'}`} onclick="event.preventDefault();">
      {color_variants && color_variants.length > 0 && (
        <div class="flex gap-2 justify-center mb-1">
          {color_variants.map((variant) => (
            <button
              class="card-color-btn w-6 h-6 rounded-full border-2 border-gray-200 focus:outline-none transition-all relative hover:scale-110"
              data-color={variant.name}
              data-img={variant.image_url}
              style={`background-color: ${variant.name === 'Blanco' ? '#f8f9fa' : variant.name === 'Negro' ? '#111827' : '#ccc'};`}
              title={variant.name}
            >
              <span class="sr-only">{variant.name}</span>
            </button>
          ))}
        </div>
      )}
      {has_sizes && (
        <>
          <select class={`quick-add-size w-full border border-gray-200 rounded-lg py-2 px-3 focus:ring-celeste-500 focus:border-celeste-500 bg-white text-gray-900 cursor-pointer ${is_featured ? 'text-sm font-bold' : 'text-sm'}`}>
             <option value="">Elegí tu talle</option>
             {stock_s && stock_s > 0 ? <option value="S">Talle S</option> : null}
             {stock_m && stock_m > 0 ? <option value="M">Talle M</option> : null}
             {stock_l && stock_l > 0 ? <option value="L">Talle L</option> : null}
             {stock_xl && stock_xl > 0 ? <option value="XL">Talle XL</option> : null}
          </select>
          <div class="quick-add-oversize-tip hidden mt-2 bg-black rounded-lg p-3 text-center">
            <p class="font-display text-celeste-400 text-[10px] uppercase tracking-wider leading-relaxed">
              El calce por ser oversize es más grande que una remera normal. Sugerimos un talle menos del acostumbrado o el normal para un look holgado.
            </p>
          </div>
        </>
      )}

      <div class="flex gap-2">
        <button
          class={`btn-primary bg-celeste-500 border-celeste-500 hover:bg-black hover:border-black flex-1 font-bold add-to-cart-quick flex items-center justify-center gap-3 shadow-[0_10px_20px_-10px_rgba(0,174,239,0.5)] transition-all active:scale-95 ${is_featured ? 'py-3 text-lg animate-pulse-subtle' : 'py-2 text-sm'}`}
          data-product={JSON.stringify({id, name, price, image_url: optimizedImageUrlForCart, has_sizes})}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class={`${is_featured ? 'h-5 w-5' : 'h-4 w-4'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          Comprar
        </button>
      </div>
      <p class="quick-add-color-error text-red-500 text-xs hidden text-center mt-1">⚠️ Seleccioná un color</p>
      <p class="quick-add-error text-red-500 text-xs hidden text-center mt-1">⚠️ Seleccioná un talle</p>
    </div>
  )}
</article>

<style>
  .animate-pulse-subtle {
    animation: pulse-subtle 3s infinite;
  }
  @keyframes pulse-subtle {
    0%, 100% { transform: scale(1); box-shadow: 0 10px 20px -10px rgba(0,174,239,0.5); }
    50% { transform: scale(1.02); box-shadow: 0 15px 30px -10px rgba(0,174,239,0.7); }
  }
</style>

<script>
  import { addToCart as addFn, openCart } from '../lib/cart';

  document.addEventListener('astro:page-load', () => {
    // Gallery slideshow for cards with multiple images
    document.querySelectorAll('.product-card').forEach(card => {
      const slides = card.querySelectorAll('.gallery-slide');
      if (slides.length < 2) return;
      let current = 0;
      const interval = setInterval(() => {
        slides[current].classList.remove('opacity-100');
        slides[current].classList.add('opacity-0');
        current = (current + 1) % slides.length;
        slides[current].classList.remove('opacity-0');
        slides[current].classList.add('opacity-100');
      }, 4000);
      // Cleanup on page swap
      document.addEventListener('astro:before-preparation', () => clearInterval(interval), { once: true });
    });

    // Escuchar el cambio en el selector de talles rápido para mostrar/ocultar el disclaimer
    document.querySelectorAll('.quick-add-size').forEach(select => {
      select.addEventListener('change', (e) => {
        const s = e.currentTarget as HTMLSelectElement;
        const card = s.closest('.product-card');
        if (!card) return;
        const tip = card.querySelector('.quick-add-oversize-tip');
        if (tip) {
          if (s.value) {
            tip.classList.remove('hidden');
          } else {
            tip.classList.add('hidden');
          }
        }
      });
    });

    document.querySelectorAll('.card-color-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const b = e.currentTarget as HTMLButtonElement;
        const card = b.closest('.product-card');
        if (!card) return;
        
        card.querySelectorAll('.card-color-btn').forEach(oldBtn => oldBtn.classList.remove('ring-2', 'ring-offset-1', 'ring-black', 'border-transparent'));
        b.classList.add('ring-2', 'ring-offset-1', 'ring-black', 'border-transparent');
        
        // Use the overlay img (served from /public) to swap images without Astro hash issues
        const overlay = card.querySelector('.card-color-overlay') as HTMLImageElement;
        if (overlay) {
          const newSrc = b.dataset.img || '';
          overlay.src = newSrc;
          overlay.style.opacity = newSrc ? '1' : '0';
        }
        
        const addBtn = card.querySelector('.add-to-cart-quick') as HTMLButtonElement;
        if (addBtn) {
            addBtn.dataset.selectedColor = b.dataset.color;
            addBtn.dataset.selectedImg = b.dataset.img;
        }
        
        const err = card.querySelector('.quick-add-color-error');
        if (err) err.classList.add('hidden');
      });
    });

    document.querySelectorAll('.add-to-cart-quick').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const button = e.currentTarget as HTMLButtonElement;
        const card = button.closest('.product-card');
        if (!card) return;

        const product = JSON.parse(button.dataset.product || '{}');
        let size = 'UNICO';
        
        const colorBtns = card.querySelectorAll('.card-color-btn');
        let color = button.dataset.selectedColor;
        
        if (colorBtns.length > 0 && !color) {
            const err = card.querySelector('.quick-add-color-error');
            if (err) err.classList.remove('hidden');
            return;
        }

        if (product.has_sizes) {
           const select = card.querySelector('.quick-add-size') as HTMLSelectElement;
           if (!select || !select.value) {
              const err = card.querySelector('.quick-add-error');
              if (err) err.classList.remove('hidden');
              return;
           }
           size = select.value;
        }

        addFn({
          productId: product.id,
          name: product.name,
          size: size as any,
          color: color || undefined,
          price: product.price,
          image: button.dataset.selectedImg || product.image_url || '/images/parte de frente de la remera.webp',
        });
        
        const err = card.querySelector('.quick-add-error');
        if (err) err.classList.add('hidden');
        const colorErr = card.querySelector('.quick-add-color-error');
        if (colorErr) colorErr.classList.add('hidden');
        
        openCart();
      });
    });
  });
</script>

<style>
  @keyframes fadeOut {
    0%, 45% { opacity: 1; }
    50%, 95% { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes fadeIn {
    0%, 45% { opacity: 0; }
    50%, 95% { opacity: 1; }
    100% { opacity: 0; }
  }
  .auto-fade-out {
    animation: fadeOut 8s infinite ease-in-out;
  }
  .auto-fade-in {
    animation: fadeIn 8s infinite ease-in-out;
  }
</style>
