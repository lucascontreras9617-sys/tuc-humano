---
// Cart Drawer - side panel
---

<!-- Overlay -->
<div
  id="cart-overlay"
  class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"
></div>

<!-- Drawer -->
<aside
  id="cart-drawer"
  class="fixed top-0 right-0 h-full w-full max-w-md bg-white z-50 shadow-2xl
         transform translate-x-full transition-transform duration-300 ease-out
         flex flex-col"
>
  <!-- Header General -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 flex-shrink-0">
    <h2 class="text-lg font-bold text-gray-900">Tu Carrito</h2>
    <button id="cart-close-btn" class="p-2 text-gray-400 hover:text-gray-700 transition-colors" aria-label="Cerrar carrito">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- ==================== PASO 1: ÍTEMS ==================== -->
  <div id="step-1" class="flex flex-col flex-grow overflow-hidden min-h-0">
    <!-- Items -->
    <div id="cart-items-container" class="flex-grow overflow-y-auto scrollbar-thin px-6 py-4 space-y-4">
      <!-- Empty State -->
      <div id="cart-empty" class="flex flex-col items-center justify-center h-full text-center py-16 hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-200 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p class="text-gray-400 font-medium">Tu carrito está vacío</p>
        <a href="/tienda" class="btn-primary mt-6 text-sm">Ver tienda</a>
      </div>
    </div>

    <!-- Footer Paso 1 -->
    <div id="cart-footer-1" class="border-t border-gray-100 px-6 py-5 space-y-4 hidden flex-shrink-0 bg-white shadow-[0_-4px_10px_rgba(0,0,0,0.02)]">
      <div class="flex justify-between text-base font-bold text-gray-900">
        <span>Subtotal</span>
        <span id="cart-subtotal-1">$0</span>
      </div>
      <p class="text-xs text-gray-400">El envío se calcula en el próximo paso.</p>
      
      <button id="go-to-step-2" class="btn-primary w-full text-base py-4">
        Completar datos de envío →
      </button>
    </div>
  </div>

  <!-- ==================== PASO 2: FORMULARIO ==================== -->
  <div id="step-2" class="flex flex-col flex-grow overflow-hidden hidden bg-gray-50/50 min-h-0">
    <div class="px-6 py-3 border-b flex items-center gap-3 bg-white flex-shrink-0">
      <button id="back-to-step-1" class="text-gray-400 hover:text-gray-900 transition-colors p-1 -ml-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </button>
      <span class="text-sm font-semibold text-gray-900">Datos de Envío</span>
    </div>

    <!-- Formulario scrolleable -->
    <form id="checkout-form" class="flex-grow overflow-y-auto px-6 py-6 space-y-5">
      
      <!-- Datos Personales -->
      <div class="space-y-4">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Tus Datos</h3>
        <div class="grid grid-cols-1 gap-4">
          <input type="text" name="name" required placeholder="Nombre completo" class="form-input" />
          <input type="email" name="email" required placeholder="Correo electrónico" class="form-input" />
          <input type="tel" name="phone" required placeholder="Teléfono / WhatsApp" class="form-input" />
        </div>
      </div>

      <!-- Envío -->
      <div class="space-y-4 pt-2">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Dirección de Entrega</h3>
        
        <div class="grid grid-cols-1 gap-4">
          <select name="provincia" id="provincia-select" required class="form-input bg-white cursor-pointer appearance-none">
            <option value="" disabled selected>Provincia...</option>
            <option value="Tucumán">Tucumán</option>
            <option value="Buenos Aires">Buenos Aires</option>
            <option value="Catamarca">Catamarca</option>
            <option value="Chaco">Chaco</option>
            <option value="Chubut">Chubut</option>
            <option value="Ciudad Autónoma de Buenos Aires">Ciudad Autónoma de Buenos Aires</option>
            <option value="Córdoba">Córdoba</option>
            <option value="Corrientes">Corrientes</option>
            <option value="Entre Ríos">Entre Ríos</option>
            <option value="Formosa">Formosa</option>
            <option value="Jujuy">Jujuy</option>
            <option value="La Pampa">La Pampa</option>
            <option value="La Rioja">La Rioja</option>
            <option value="Mendoza">Mendoza</option>
            <option value="Misiones">Misiones</option>
            <option value="Neuquén">Neuquén</option>
            <option value="Río Negro">Río Negro</option>
            <option value="Salta">Salta</option>
            <option value="San Juan">San Juan</option>
            <option value="San Luis">San Luis</option>
            <option value="Santa Cruz">Santa Cruz</option>
            <option value="Santa Fe">Santa Fe</option>
            <option value="Santiago del Estero">Santiago del Estero</option>
            <option value="Tierra del Fuego">Tierra del Fuego</option>
          </select>

          <div class="grid grid-cols-3 gap-4">
            <input type="text" name="localidad" required placeholder="Localidad" class="form-input col-span-2" />
            <input type="text" name="cp" id="cp-input" required placeholder="C.P." class="form-input" />
          </div>

          <div class="grid grid-cols-3 gap-4">
            <input type="text" name="calle" required placeholder="Calle" class="form-input col-span-2" />
            <input type="text" name="numero" required placeholder="Número" class="form-input" />
          </div>

          <input type="text" name="depto" placeholder="Piso / Depto / Casa (Opcional)" class="form-input" />
          <textarea name="aclaraciones" placeholder="Aclaraciones para encontrar el lugar u observaciones..." rows="2" class="form-input resize-none"></textarea>
        </div>
      </div>

      <!-- Cotizador dinámico -->
      <div id="shipping-options-wrapper" class="bg-celeste-50 rounded-xl p-4 border border-celeste-100 hidden">
        <p class="text-xs font-bold text-celeste-700 mb-3 uppercase tracking-wider flex items-center justify-between">
          <span>Opciones de Envío</span>
          <span id="shipping-loader" class="hidden w-3 h-3 rounded-full border-2 border-celeste-500 border-t-transparent animate-spin"></span>
        </p>
        <div id="shipping-options-container" class="space-y-2">
          <!-- Opciones inyectadas vía JS -->
        </div>
      </div>

    </form>

    <!-- Footer Paso 2 -->
    <div class="border-t border-gray-100 bg-white px-6 py-5 flex-shrink-0 shadow-[0_-10px_20px_rgba(0,0,0,0.03)] z-10">
      <div class="flex justify-between text-sm text-gray-500 mb-1">
        <span>Productos</span>
        <span id="cart-subtotal-2">$0</span>
      </div>
      <div class="flex justify-between text-sm text-gray-500 mb-3">
        <span>Envío</span>
        <span id="cart-shipping-cost">$0</span>
      </div>
      <div class="flex justify-between text-lg font-black text-gray-900 mb-4 border-t border-gray-100 pt-3">
        <span>Total a Pagar</span>
        <span id="cart-total-final">$0</span>
      </div>
      
      <button id="checkout-btn" class="btn-primary w-full text-base py-4 flex items-center justify-center gap-2 opacity-50 cursor-not-allowed" disabled>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <span>Pagar Compra</span>
      </button>
      <p id="checkout-error" class="text-red-500 text-xs text-center mt-2 hidden"></p>
    </div>
  </div>

</aside>

<style>
  .form-input {
    @apply w-full px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-celeste-500 focus:border-transparent text-gray-900;
  }
</style>

<script>
  import { cartItems, cartSubtotal, cartOpen, closeCart, removeFromCart, updateQuantity, clearCart } from '../lib/cart';

  document.addEventListener('astro:page-load', () => {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    const closeBtn = document.getElementById('cart-close-btn');
    
    if (!drawer || !overlay || !closeBtn) return;

    // Elementos Paso 1
    const step1 = document.getElementById('step-1')!;
    const itemsContainer = document.getElementById('cart-items-container')!;
    const emptyMsg = document.getElementById('cart-empty')!;
    const cartFooter1 = document.getElementById('cart-footer-1')!;
    const subtotalEl1 = document.getElementById('cart-subtotal-1')!;
    const skipToStep2Btn = document.getElementById('go-to-step-2')!;

    // Elementos Paso 2
    const step2 = document.getElementById('step-2')!;
    const backBtn = document.getElementById('back-to-step-1')!;
    const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement;
    const provinciaSelect = document.getElementById('provincia-select') as HTMLSelectElement;
    const cpInput = document.getElementById('cp-input') as HTMLInputElement;
    const shippingWrapper = document.getElementById('shipping-options-wrapper')!;
    const shippingContainer = document.getElementById('shipping-options-container')!;
    const shippingLoader = document.getElementById('shipping-loader')!;
    const subtotalEl2 = document.getElementById('cart-subtotal-2')!;
    const shippingCostEl = document.getElementById('cart-shipping-cost')!;
    const finalTotalEl = document.getElementById('cart-total-final')!;
    const checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement;
    const checkoutError = document.getElementById('checkout-error')!;

    let shippingCost = 0;
    let selectedShippingMethod = '';

    function formatPrice(n: number) {
      return new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(n);
    }

    // --- DRAWER TOGGLE ---
    function openDrawer() {
      drawer.classList.remove('translate-x-full');
      overlay.classList.remove('hidden');
      setTimeout(() => overlay.classList.remove('opacity-0'), 10);
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.add('translate-x-full');
      overlay.classList.add('opacity-0');
      setTimeout(() => overlay.classList.add('hidden'), 300);
      closeCart();
      document.body.style.overflow = '';
    }

    // Clean up previous listeners if necessary (though astro handles it usually)
    const unsubOpen = cartOpen.subscribe((open) => {
      if (open) openDrawer();
      else closeDrawer();
    });

    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);

    // --- NAVIGATION STEPS ---
    skipToStep2Btn.addEventListener('click', () => {
      step1.classList.add('hidden');
      step2.classList.remove('hidden');
      validateForm();
    });

    backBtn.addEventListener('click', () => {
      step2.classList.add('hidden');
      step1.classList.remove('hidden');
    });

    // --- RENDERING ITEMS ---
    function renderItems(items: readonly any[]) {
      itemsContainer.querySelectorAll('.cart-item-row').forEach(el => el.remove());
      const isEmpty = items.length === 0;
      emptyMsg.classList.toggle('hidden', !isEmpty);
      cartFooter1.classList.toggle('hidden', isEmpty);

      if (isEmpty) {
        step2.classList.add('hidden');
        step1.classList.remove('hidden');
      }

      items.forEach((item) => {
        const row = document.createElement('div');
        row.className = 'cart-item-row flex gap-4 items-start py-3 border-b border-gray-50';
        row.innerHTML = `
          <img src="${item.image}" alt="${item.name}" class="w-16 h-20 object-cover rounded-lg flex-shrink-0 bg-gray-100" />
          <div class="flex-grow min-w-0">
            <p class="font-semibold text-gray-900 text-sm leading-tight truncate">${item.name}</p>
            <p class="text-celeste-500 text-xs mt-0.5">Talle: <strong>${item.size}</strong></p>
            <p class="text-gray-900 font-bold text-sm mt-0.5">${formatPrice(item.price)}</p>
            <div class="flex items-center gap-2 mt-1.5">
              <button data-pid="${item.productId}" data-size="${item.size}" data-action="dec"
                class="w-6 h-6 rounded-md bg-gray-50 flex items-center justify-center text-gray-500 hover:bg-celeste-50 hover:text-celeste-600 qty-btn">−</button>
              <span class="text-xs font-semibold w-4 text-center">${item.quantity}</span>
              <button data-pid="${item.productId}" data-size="${item.size}" data-action="inc"
                class="w-6 h-6 rounded-md bg-gray-50 flex items-center justify-center text-gray-500 hover:bg-celeste-50 hover:text-celeste-600 qty-btn">+</button>
              <button data-pid="${item.productId}" data-size="${item.size}" data-action="remove"
                class="ml-auto text-gray-300 hover:text-red-400 p-1 remove-btn">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </div>
        `;
        itemsContainer.insertBefore(row, emptyMsg);
      });

      // qty buttons listeners
      itemsContainer.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const b = e.currentTarget as HTMLButtonElement;
          const pid = b.dataset.pid!;
          const size = b.dataset.size!;
          const item = cartItems.get().find(i => i.productId === pid && i.size === size);
          if (!item) return;
          if (b.dataset.action === 'inc') updateQuantity(pid, size, item.quantity + 1);
          else if (b.dataset.action === 'dec') updateQuantity(pid, size, item.quantity - 1);
          
          if (!step2.classList.contains('hidden')) {
            calculateShipping();
          }
        });
      });

      itemsContainer.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const b = e.currentTarget as HTMLButtonElement;
          removeFromCart(b.dataset.pid!, b.dataset.size!);
          if (!step2.classList.contains('hidden')) calculateShipping();
        });
      });
    }

    const unsubItems = cartItems.subscribe(renderItems);

    function updateTotalUI() {
      const sub = cartSubtotal.get();
      subtotalEl1.textContent = formatPrice(sub);
      subtotalEl2.textContent = formatPrice(sub);
      shippingCostEl.textContent = shippingCost === 0 ? (selectedShippingMethod ? 'Gratis' : '$0') : formatPrice(shippingCost);
      finalTotalEl.textContent = formatPrice(sub + shippingCost);
    }
    const unsubSub = cartSubtotal.subscribe(updateTotalUI);

    // --- FORM LOGIC & SHIPPING CALC ---
    let calcTimeout: any = null;

    function handleShippingOptionClick(e: Event) {
      const input = e.currentTarget as HTMLInputElement;
      shippingCost = Number(input.value);
      selectedShippingMethod = input.dataset.name || 'Envío';
      updateTotalUI();
      validateForm();
    }

    function injectShippingOptions(options: any[]) {
      shippingContainer.innerHTML = '';
      
      const isTucuman = provinciaSelect.value === 'Tucumán' || cpInput.value.startsWith('40') || cpInput.value.startsWith('41');
      let finalOptions = [...options];

      if (isTucuman) {
        finalOptions.unshift({
          nombre: 'Acordar envío por WhatsApp o Retiro (Sólo S.M. Tucumán / Yerba Buena / Tafí Viejo / Alderetes / La Banda)',
          precio: 0,
          dias: 'Coordinamos horario'
        });
      }

      finalOptions.forEach((opt, idx) => {
        const isChecked = idx === 0;
        if (isChecked) {
          shippingCost = opt.precio;
          selectedShippingMethod = opt.nombre;
        }
        
        const el = document.createElement('label');
        el.className = 'flex items-start gap-3 p-3 bg-white rounded-lg border border-celeste-100 cursor-pointer hover:border-celeste-300 transition-colors';
        el.innerHTML = `
          <input type="radio" name="shipping_method" value="${opt.precio}" data-name="${opt.nombre}" class="mt-1 text-celeste-600 focus:ring-celeste-500 shipping-radio" ${isChecked ? 'checked' : ''} />
          <div class="flex-grow">
            <div class="flex justify-between items-center">
              <span class="text-sm font-semibold text-gray-900 leading-tight pr-2">${opt.nombre}</span>
              <span class="text-sm font-black text-celeste-600 whitespace-nowrap">${opt.precio === 0 ? '¡Gratis!' : formatPrice(opt.precio)}</span>
            </div>
            <span class="text-xs text-gray-500">${opt.dias}</span>
          </div>
        `;
        shippingContainer.appendChild(el);
      });

      shippingContainer.querySelectorAll('.shipping-radio').forEach(r => {
        r.addEventListener('change', handleShippingOptionClick);
      });

      shippingWrapper.classList.remove('hidden');
      updateTotalUI();
      validateForm();
    }

    async function calculateShipping() {
      const cp = cpInput.value.trim();
      if (cp.length < 4) return;

      shippingLoader.classList.remove('hidden');
      shippingWrapper.classList.remove('hidden');
      shippingContainer.innerHTML = '<p class="text-sm text-gray-400 p-2 text-center">Calculando envíos...</p>';
      
      try {
        const items = cartItems.get();
        const provincia = provinciaSelect.value;
        const res = await fetch('/api/shipping-calculator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ cp_destino: cp, provincia, items })
        });
        const data = await res.json();

        if (data.error) {
          shippingContainer.innerHTML = `<p class="text-xs text-red-500 p-2 font-semibold">${data.error}</p>`;
          shippingCost = 0;
          selectedShippingMethod = '';
          
          cpInput.classList.add('border-red-500', 'focus:ring-red-500', 'text-red-700', 'bg-red-50');
          cpInput.classList.remove('border-gray-200', 'focus:ring-celeste-500');
        } else {
          cpInput.classList.remove('border-red-500', 'focus:ring-red-500', 'text-red-700', 'bg-red-50');
          cpInput.classList.add('border-gray-200', 'focus:ring-celeste-500');

          injectShippingOptions(data.options);
        }
      } catch {
        shippingContainer.innerHTML = '<p class="text-xs text-red-500 p-2">Error de conexión base.</p>';
        shippingCost = 0;
        selectedShippingMethod = '';
      } finally {
        shippingLoader.classList.add('hidden');
        updateTotalUI();
      }
    }

    cpInput.addEventListener('input', () => {
      cpInput.classList.remove('border-red-500', 'focus:ring-red-500', 'text-red-700', 'bg-red-50');
      cpInput.classList.add('border-gray-200', 'focus:ring-celeste-500');

      if (calcTimeout) clearTimeout(calcTimeout);
      if (cpInput.value.trim().length >= 4) {
        calcTimeout = setTimeout(() => {
          calculateShipping();
        }, 800);
      } else {
        shippingWrapper.classList.add('hidden');
        shippingCost = 0;
        selectedShippingMethod = '';
        updateTotalUI();
        validateForm();
      }
    });

    provinciaSelect.addEventListener('change', () => {
      if (cpInput.value.trim().length >= 4) {
        calculateShipping();
      }
      validateForm();
    });

    checkoutForm.addEventListener('input', validateForm);

    function validateForm() {
      const isValid = checkoutForm.checkValidity() && selectedShippingMethod !== '';
      if (isValid) {
        checkoutBtn.removeAttribute('disabled');
        checkoutBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      } else {
        checkoutBtn.setAttribute('disabled', 'true');
        checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
      }
    }

    checkoutBtn.addEventListener('click', async (e) => {
      e.preventDefault();

      if (!checkoutForm.checkValidity() || !selectedShippingMethod) {
        checkoutForm.reportValidity();
        return;
      }

      const items = cartItems.get();
      if (!items.length) return;

      checkoutBtn.innerHTML = '<span class="animate-pulse">Abriendo WhatsApp...</span>';
      checkoutBtn.setAttribute('disabled', 'true');
      checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
      checkoutError.classList.add('hidden');

      const fd = new FormData(checkoutForm);
      const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '5493816447082';
      
      let productsText = '';
      items.forEach(item => {
        productsText += `- ${item.quantity}x ${item.name} (Talle: ${item.size}) - ${formatPrice(item.price * item.quantity)}\n`;
      });

      const subtotal = cartSubtotal.get();
      const total = subtotal + shippingCost;

      const deptoStr = fd.get('depto') ? ` (Depto: ${fd.get('depto')})` : '';
      const aclaracionesStr = fd.get('aclaraciones') ? `\nAclaraciones: ${fd.get('aclaraciones')}` : '';

      const message = `¡Hola TUC-HUMANO! Quiero confirmar el siguiente pedido:

*📝 DETALLE DEL PEDIDO:*
${productsText}
*Subtotal:* ${formatPrice(subtotal)}
*Envío* (${selectedShippingMethod}): ${shippingCost === 0 ? 'Gratis' : formatPrice(shippingCost)}

*💰 TOTAL A PAGAR: ${formatPrice(total)}*

*👤 DATOS DEL CLIENTE:*
Nombre: ${fd.get('name')}
Email: ${fd.get('email')}
Teléfono: ${fd.get('phone')}

*🚚 DIRECCIÓN DE ENVÍO:*
${fd.get('calle')} ${fd.get('numero')}${deptoStr}
${fd.get('localidad')}, ${fd.get('provincia')} (CP: ${fd.get('cp')})${aclaracionesStr}

¡Espero los datos para realizar la transferencia!`;

      const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;
      
      window.location.href = waUrl;
      clearCart();
      closeDrawer();
      
      setTimeout(() => {
        checkoutBtn.innerHTML = `
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <span>Pagar Compra</span>
        `;
        checkoutBtn.removeAttribute('disabled');
        checkoutBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      }, 1500);
    });
  });
</script>
