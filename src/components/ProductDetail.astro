---
import { Image, getImage, Picture } from 'astro:assets';
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}');

interface Props {
  product: {
    id: string;
    name: string;
    price: number;
    old_price: number | null;
    description: string;
    image_url: string;
    image_back_url: string | null;
    stock_s: number;
    stock_m: number;
    stock_l: number;
    stock_xl: number;
    stock_unico: number;
    has_sizes: boolean;
    color_variants?: { name: string, image_url: string, image_back_url?: string }[] | null;
  };
}

const { product } = Astro.props;

const formatPrice = (p: number) => new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
}).format(p);

const formatted = formatPrice(product.price);
const formattedOld = product.old_price ? formatPrice(product.old_price) : null;
const discountPercent = product.old_price ? Math.round(((product.old_price - product.price) / product.old_price) * 100) : 0;

const sizes = product.has_sizes ? [
  { label: 'S',  stock: product.stock_s  },
  { label: 'M',  stock: product.stock_m  },
  { label: 'L',  stock: product.stock_l  },
  { label: 'XL', stock: product.stock_xl },
] : [];

const hasStock = product.has_sizes 
  ? (product.stock_s > 0 || product.stock_m > 0 || product.stock_l > 0 || product.stock_xl > 0)
  : (product.stock_unico > 0);

const imagePath1 = `/src/assets${product.image_url}`;
const imagePath2 = product.image_back_url ? `/src/assets${product.image_back_url}` : null;

const img1 = imagesGlob[imagePath1] ? (await imagesGlob[imagePath1]()).default : null;
const img2 = imagePath2 && imagesGlob[imagePath2] ? (await imagesGlob[imagePath2]()).default : null;

let optimizedImageUrlForCart = product.image_url;
let optimizedImageBackUrlForCart = product.image_back_url;

if (imagesGlob[imagePath1]) {
  const optimized = await getImage({ src: imagesGlob[imagePath1]() });
  optimizedImageUrlForCart = optimized.src;
}
if (imagePath2 && imagesGlob[imagePath2]) {
  const optimized = await getImage({ src: imagesGlob[imagePath2]() });
  optimizedImageBackUrlForCart = optimized.src;
}

const productForClient = {
  ...product,
  image_url: optimizedImageUrlForCart,
  image_back_url: optimizedImageBackUrlForCart
};
---

<div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-10 lg:gap-16 items-start">
  
  <div id="product-ctx" data-product={JSON.stringify(productForClient)} class="hidden"></div>

  <!-- Gallery -->
  <div class="space-y-3">
    <div class="relative aspect-[3/4] rounded-xl overflow-hidden bg-gray-50 group border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
      {img1 ? (
        <Picture
          id="main-product-img"
          src={img1}
          alt={product.name}
          formats={['webp']}
          widths={[600, 900, 1200, 1600]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 60vw, 800px"
          width={img1.width}
          height={img1.height}
          class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
          loading="eager"
          fetchpriority="high"
          quality={90}
        />
      ) : (
        <Picture
          id="main-product-img"
          src={product.image_url}
          alt={product.name}
          formats={['webp']}
          widths={[600, 900, 1200, 1600]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 60vw, 800px"
          width={600}
          height={800}
          class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
          loading="eager"
          fetchpriority="high"
          quality={90}
        />
      )}
      {/* Overlay img for color-swap (uses public/images, not hashed Astro assets) */}
      {product.color_variants && product.color_variants.length > 0 && (
        <img
          id="color-swap-overlay"
          class="absolute inset-0 w-full h-full object-cover object-top opacity-0 transition-opacity duration-300"
          src=""
          alt={product.name}
          aria-hidden="true"
        />
      )}
      {/* Gallery overlay - for thumbnail clicks when product has gallery_images */}
      {product.gallery_images && product.gallery_images.length > 0 && (
        <img
          id="gallery-swap-overlay"
          class="absolute inset-0 w-full h-full object-cover object-center opacity-0 transition-opacity duration-300 z-5"
          src={product.image_url}
          alt={product.name}
          aria-hidden="true"
        />
      )}
      {discountPercent > 0 && (
        <div class="absolute top-4 left-4 z-10">
          <span class="bg-red-500 text-white text-sm font-bold px-4 py-2 rounded-full shadow-lg">
            -{discountPercent}% OFF
          </span>
        </div>
      )}
    </div>
    <!-- Thumbnails -->
    {product.gallery_images && product.gallery_images.length > 0 ? (
      <div class="flex gap-3 mt-4">
        {product.gallery_images.map((img, idx) => (
          <button
            class={`thumb-btn flex-1 aspect-[3/4] rounded-xl overflow-hidden border-4 ${idx === 0 ? 'border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]' : 'border-transparent hover:border-black'} transition-colors`}
            data-src={img}
          >
            <img
              src={img}
              alt={`Vista ${idx + 1}`}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </button>
        ))}
      </div>
    ) : product.image_back_url && !(product.color_variants && product.color_variants.length > 0) ? (
      <div class="flex gap-3">
        <button
          class="thumb-btn flex-1 aspect-[3/4] rounded-xl overflow-hidden border-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
          data-src={optimizedImageUrlForCart}
        >
          {img1 ? (
            <Picture
              src={img1}
              alt="Frente"
              formats={['avif', 'webp']}
              widths={[200, 400]}
              sizes="150px"
              width={img1.width}
              height={img1.height}
              class="w-full h-full object-cover"
              loading="eager"
              quality={80}
            />
          ) : (
            <Picture
              src={product.image_url}
              alt="Frente"
              formats={['avif', 'webp']}
              widths={[200, 400]}
              sizes="150px"
              width={150}
              height={200}
              class="w-full h-full object-cover"
              loading="eager"
              quality={80}
            />
          )}
        </button>
        <button
          class="thumb-btn flex-1 aspect-[3/4] rounded-xl overflow-hidden border-4 border-transparent hover:border-black transition-colors"
          data-src={optimizedImageBackUrlForCart}
        >
          {img2 ? (
            <Picture
              src={img2}
              alt="Espalda"
              formats={['avif', 'webp']}
              widths={[200, 400]}
              sizes="150px"
              width={img2.width}
              height={img2.height}
              class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity"
              loading="eager"
              quality={80}
            />
          ) : (
            <Picture
              src={product.image_back_url}
              alt="Espalda"
              formats={['avif', 'webp']}
              widths={[200, 400]}
              sizes="150px"
              width={150}
              height={200}
              class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity"
              loading="eager"
              quality={80}
            />
          )}
        </button>
      </div>
    ) : null}
  </div>

  <!-- Info -->
  <div class="space-y-6 lg:sticky lg:top-24">
    <div>
      {product.has_sizes && (
        <span class="inline-block bg-celeste-100 text-celeste-700 text-xs font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wider">
          Remera Oversize
        </span>
      )}
      <h1 class="text-3xl font-bold text-gray-900 leading-tight">{product.name}</h1>
      
      <div class="flex items-center gap-4 mt-3">
        <p class="text-4xl font-black text-celeste-500">{formatted}</p>
        {formattedOld && (
          <p class="text-xl text-gray-400 line-through decoration-red-400/50">{formattedOld}</p>
        )}
      </div>
      <p class="text-gray-400 text-sm mt-1">+ costo de envío (calcular en el carrito)</p>
    </div>

    <!-- Description -->
    <div class="text-gray-600 leading-relaxed text-sm border-l-4 border-celeste-200 pl-4 space-y-4" set:html={product.description}>
    </div>

    {hasStock ? (
      <>
        <!-- CTA Button (Moved to top for prominence) -->
        <div class="pt-2">
          <button id="add-to-cart-btn" class="btn-primary w-full py-5 text-xl bg-celeste-500 border-celeste-500 hover:bg-black hover:border-black shadow-[0_10px_20px_-10px_rgba(0,174,239,0.5)] transition-all transform hover:-translate-y-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Comprar
          </button>
        </div>

        <!-- Color Selector -->
        {product.color_variants && product.color_variants.length > 0 && (
          <div class="mt-8">
            <div class="flex items-center justify-between mb-3">
              <p class="font-semibold text-gray-900 text-sm">Elegí tu color</p>
              <span id="color-error" class="text-red-400 text-xs hidden">Seleccioná un color</span>
            </div>
            <div class="flex gap-3">
              {product.color_variants.map((variant) => (
                <button
                  class="color-btn w-10 h-10 rounded-full border-2 border-gray-200 focus:outline-none transition-all flex items-center justify-center relative shadow-sm hover:scale-110"
                  data-color={variant.name}
                  data-img={variant.image_url}
                  data-img-back={variant.image_back_url || ''}
                  style={`background-color: ${variant.name === 'Blanco' ? '#f8f9fa' : variant.name === 'Negro' ? '#111827' : '#ccc'};`}
                  title={variant.name}
                >
                  <span class="sr-only">{variant.name}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Size Selector -->
        {product.has_sizes ? (
          <div class="mt-8">
            <div class="flex items-center justify-between mb-3">
              <p class="font-semibold text-gray-900 text-sm">Elegí tu talle</p>
              <span id="size-error" class="text-red-400 text-xs hidden">Seleccioná un talle</span>
            </div>
            <div class="flex gap-3">
              {sizes.map(({ label, stock }) => (
                <button
                  class={'size-btn ' + (stock === 0 ? 'out-of-stock' : '')}
                  data-size={label}
                  data-stock={stock}
                  disabled={stock === 0}
                  title={stock === 0 ? 'Sin stock' : 'Stock: ' + stock}
                >
                  {label}
                </button>
              ))}
            </div>
            <p id="stock-indicator" class="text-xs text-gray-400 mt-2"></p>
            <div id="oversize-tip" class="hidden mt-3 bg-black rounded-lg p-4 text-center">
              <p class="font-display text-celeste-400 text-xs uppercase tracking-wider leading-relaxed">
                El calce de las remeras por ser oversize es más grande que el de una remera normal. Sugerimos elegir un talle menos del que acostumbrás o, para un look más holgado, el talle normal.
              </p>
            </div>
          </div>
        ) : (
          <div class="mt-4">
             <p id="stock-indicator" class="text-xs text-gray-400">
               {product.stock_unico <= 5 && product.stock_unico > 0 ? '⚠️ Últimas ' + product.stock_unico + ' unidades' : 'Stock disponible'}
             </p>
          </div>
        )}

        <!-- Quantity -->
        <div class="mt-6">
          <p class="font-semibold text-gray-900 text-sm mb-3">Cantidad</p>
          <div class="flex items-center gap-4">
            <button id="qty-dec" class="w-10 h-10 rounded-full border-2 border-gray-200 flex items-center justify-center text-gray-500 hover:border-celeste-500 hover:text-celeste-500 transition-colors font-bold text-lg">−</button>
            <span id="qty-display" class="text-lg font-bold w-8 text-center text-gray-900">1</span>
            <button id="qty-inc" class="w-10 h-10 rounded-full border-2 border-gray-200 flex items-center justify-center text-gray-500 hover:border-celeste-500 hover:text-celeste-500 transition-colors font-bold text-lg">+</button>
          </div>
        </div>
      </>
    ) : (
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 text-center mt-6">
        <p class="text-gray-900 font-bold text-lg mb-2">Producto sin stock</p>
        <p class="text-gray-500 text-sm mb-4">Dejanos tu email y te avisamos cuando vuelva a ingresar.</p>
        <div class="flex gap-2">
          <input type="email" placeholder="Tu email..." class="flex-1 rounded-lg border-gray-300 shadow-sm focus:border-celeste-500 focus:ring-celeste-500" />
          <button class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors">Avisarme</button>
        </div>
      </div>
    )}

    <!-- Features -->
    {product.has_sizes ? (
      <div class="grid grid-cols-2 gap-3 pt-4 border-t border-gray-100">
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Algodón premium</div>
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Fit oversize</div>
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Diseño único</div>
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Todos los cuerpos</div>
      </div>
    ) : (
      <div class="grid grid-cols-2 gap-3 pt-4 border-t border-gray-100">
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Calidad garantizada</div>
        <div class="flex items-center gap-2 text-sm text-gray-500"><span class="text-celeste-500">✓</span> Envíos a todo el país</div>
      </div>
    )}
  </div>
</div>

<script>
  import { addToCart as addFn, openCart } from '../lib/cart';

  document.addEventListener('astro:page-load', () => {
    const ctxEl = document.getElementById('product-ctx');
    if (ctxEl) {
      const product = JSON.parse(ctxEl.dataset.product || '{}');
      const hasSizes = product.has_sizes;
      const hasColors = product.color_variants && product.color_variants.length > 0;
      let selectedSize: string | null = hasSizes ? null : 'UNICO';
      let selectedColor: string | null = null;
      let quantity = 1;
      let maxStock = hasSizes ? 0 : product.stock_unico;

      const stockMap: Record<string, number> = {
        S:  product.stock_s,
        M:  product.stock_m,
        L:  product.stock_l,
        XL: product.stock_xl,
      };

      // Thumbnail switcher
      document.querySelectorAll('.thumb-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const src = target.dataset.src;
          const galleryOverlay = document.getElementById('gallery-swap-overlay') as HTMLImageElement;
          const colorOverlay = document.getElementById('color-swap-overlay') as HTMLImageElement;
          
          if (src) {
            const colorOverlay = document.getElementById('color-swap-overlay') as HTMLImageElement;
            if (galleryOverlay) {
              // Use gallery overlay for clean src swapping without hash issues
              // But if color-overlay is active (color was selected), update that instead
              if (colorOverlay && colorOverlay.style.opacity === '1') {
                colorOverlay.src = src;
              } else {
                galleryOverlay.src = src;
                galleryOverlay.style.opacity = '1';
              }
            } else if (colorOverlay && colorOverlay.style.opacity === '1') {
              colorOverlay.src = src;
            } else {
              const mainImg = document.getElementById('main-product-img');
              if (mainImg) {
                if (mainImg.tagName.toUpperCase() === 'PICTURE') {
                  const img = mainImg.querySelector('img');
                  const sources = mainImg.querySelectorAll('source');
                  if (img) img.src = src;
                  sources.forEach(s => s.srcset = src);
                } else {
                  (mainImg as HTMLImageElement).src = src;
                }
              }
            }
          }
          document.querySelectorAll('.thumb-btn').forEach(b => {
            b.classList.remove('border-black', 'shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]');
            b.classList.add('border-transparent');
          });
          target.classList.remove('border-transparent');
          target.classList.add('border-black', 'shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]');
        });
      });

      // Color selection
      if (hasColors) {
        document.querySelectorAll('.color-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const b = e.currentTarget as HTMLButtonElement;
            document.querySelectorAll('.color-btn').forEach(oldBtn => oldBtn.classList.remove('ring-2', 'ring-offset-2', 'ring-black', 'border-transparent'));
            b.classList.add('ring-2', 'ring-offset-2', 'ring-black', 'border-transparent');
            
            selectedColor = b.dataset.color || null;
            
            const colorErr = document.getElementById('color-error');
            if (colorErr) colorErr.classList.add('hidden');
            
            // Use overlay img to avoid Astro hash issues with <Picture>
            const overlay = document.getElementById('color-swap-overlay') as HTMLImageElement;
            const galleryOverlay = document.getElementById('gallery-swap-overlay') as HTMLImageElement;
            const imgSrc = b.dataset.img || '';
            // Hide gallery overlay so color overlay takes full control
            if (galleryOverlay) galleryOverlay.style.opacity = '0';
            if (overlay) {
              overlay.src = imgSrc;
              overlay.style.opacity = imgSrc ? '1' : '0';
            }
            
            const thumbsContainer = document.querySelector('.thumb-btn')?.parentElement;
            if (thumbsContainer) {
              const thumbBtns = thumbsContainer.querySelectorAll('.thumb-btn');
              if (thumbBtns[0]) {
                (thumbBtns[0] as HTMLElement).dataset.src = imgSrc;
                const imgF = thumbBtns[0].querySelector('img, picture img');
                if (imgF) (imgF as HTMLImageElement).src = imgSrc;
              }
              if (thumbBtns[1]) {
                const backSrc = b.dataset.imgBack || '';
                // Always keep the thumbnail visible — just update its image
                (thumbBtns[1] as HTMLElement).dataset.src = backSrc || imgSrc;
                const imgE = thumbBtns[1].querySelector('img, picture img');
                if (imgE) (imgE as HTMLImageElement).src = backSrc || imgSrc;
                // Dim the thumbnail if there's no specific back image for this color
                thumbBtns[1].classList.toggle('opacity-30', !backSrc);
              }
            }
          });
        });
      }

      // Size selection
      if (hasSizes) {
        document.querySelectorAll('.size-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const b = e.currentTarget as HTMLButtonElement;
            if (b.disabled) return;
            
            document.querySelectorAll('.size-btn').forEach(oldBtn => oldBtn.classList.remove('selected'));
            b.classList.add('selected');
            
            selectedSize = b.dataset.size || null;
            if (selectedSize) {
              maxStock = stockMap[selectedSize] || 0;
            }
            quantity = 1;
            
            const qtyDisp = document.getElementById('qty-display');
            if (qtyDisp) qtyDisp.textContent = '1';
            
            const sizeErr = document.getElementById('size-error');
            if (sizeErr) sizeErr.classList.add('hidden');
            
            const stockInd = document.getElementById('stock-indicator');
            if (stockInd) stockInd.textContent = maxStock <= 3 ? `⚠️ Últimas ${maxStock} unidades` : '';

            // Mostrar disclaimer oversize
            const oversizeTip = document.getElementById('oversize-tip');
            if (oversizeTip) oversizeTip.classList.remove('hidden');
          });
        });
      }

      // Quantity
      document.getElementById('qty-dec')?.addEventListener('click', () => {
        if (quantity > 1) {
          quantity--;
          const disp = document.getElementById('qty-display');
          if (disp) disp.textContent = String(quantity);
        }
      });

      document.getElementById('qty-inc')?.addEventListener('click', () => {
        if (quantity < maxStock) {
          quantity++;
          const disp = document.getElementById('qty-display');
          if (disp) disp.textContent = String(quantity);
        }
      });

      function addToCart() {
        if (hasSizes && !selectedSize) {
          const errEl = document.getElementById('size-error');
          if (errEl) errEl.classList.remove('hidden');
          return;
        }

        if (hasColors && !selectedColor) {
          const errEl = document.getElementById('color-error');
          if (errEl) errEl.classList.remove('hidden');
          return;
        }

        for (let i = 0; i < quantity; i++) {
          addFn({
            productId: product.id,
            name: product.name,
            size: (selectedSize || 'UNICO') as any,
            color: selectedColor || undefined,
            price: product.price,
            image: (hasColors && selectedColor) ? 
              (product.color_variants.find((c: any) => c.name === selectedColor)?.image_url || product.image_url) : 
              (product.image_url || '/images/parte de frente de la remera.webp'),
          });
        }
        openCart();
        
        const btn = document.getElementById('add-to-cart-btn');
        if (btn) {
          const originalText = btn.innerHTML;
          btn.innerHTML = '¡Agregado al carrito!';
          btn.classList.add('bg-celeste-500', 'border-celeste-500', 'text-white');
          setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.remove('bg-celeste-500', 'border-celeste-500', 'text-white');
          }, 1500);
        }
      }

      document.getElementById('add-to-cart-btn')?.addEventListener('click', addToCart);
    }
  });
</script>
