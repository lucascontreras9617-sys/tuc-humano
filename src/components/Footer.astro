---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo_y_marca_de_la_pagina.webp';
import igImg from '../assets/images/instagram.png';

// Footer
---

<footer class="bg-gray-950 text-white mt-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <Image
            src={logoImg}
            alt="TUC-HUMANO"
            class="h-12 w-auto brightness-0 invert"
            loading="eager"
          />
        </div>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Una identidad que camina con vos en cada lucha, en cada calle y en
          cada abrazo colectivo. Nacemos desde Tucumán.
        </p>
        <!-- Redes -->
        <div class="flex gap-4 pt-2">
          <a
            href="https://www.instagram.com/patriagrande.tuc/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-celeste-400 transition-colors inline-block"
            aria-label="Instagram Patria Grande Tucumán"
          >
            <Image src={igImg} alt="Instagram" class="h-5 w-5 brightness-0 invert opacity-70 hover:opacity-100 transition-opacity" loading="eager" />
          </a>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5493816447082"}`}
            target="_blank"
            rel="noopener"
            class="text-gray-400 hover:text-celeste-400 transition-colors"
            aria-label="WhatsApp"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3
          class="font-semibold text-white mb-4 text-sm uppercase tracking-wider"
        >
          Navegación
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/"
              class="text-gray-400 hover:text-celeste-400 text-sm transition-colors"
              >Inicio</a>
          </li>
          <li>
            <a
              href="/tienda"
              class="text-gray-400 hover:text-celeste-400 text-sm transition-colors"
              >Tienda</a>
          </li>
          <li>
            <a
              href="/#lookbook"
              class="text-gray-400 hover:text-celeste-400 text-sm transition-colors"
              >Lookbook</a>
          </li>
          <li>
            <a
              href="/#valores"
              class="text-gray-400 hover:text-celeste-400 text-sm transition-colors"
              >Nosotros</a>
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3
          class="font-semibold text-white mb-4 text-sm uppercase tracking-wider"
        >
          Contacto
        </h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-2 text-sm text-gray-400">
            <svg
              class="h-4 w-4 text-celeste-400 flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            <a
              href="tel:+5493816447082"
              class="hover:text-celeste-400 transition-colors">3816 44-7082</a
            >
          </li>
          <li class="text-sm text-gray-400">Tucumán, Argentina</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="border-t border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-gray-500 text-xs">
        © {new Date().getFullYear()} TUC-HUMANO. Todos los derechos reservados.
      </p>
      <p class="text-gray-600 text-xs">Diseñado con identidad en Tucumán</p>
    </div>
  </div>
</footer>
