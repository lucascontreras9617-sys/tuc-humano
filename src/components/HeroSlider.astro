---
// src/components/HeroSlider.astro
import { Image } from 'astro:assets';
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}');

const slides = [
  { url: '/src/assets/images/foto_portada_slide_lateral.webp', title: 'RESISTENCIA URBANA', position: 'object-center' },
  { url: '/src/assets/images/foto 1.webp', title: 'NUESTRA GENTE', position: 'object-center' },
  { url: '/src/assets/images/foto 2.webp', title: 'NUESTRO ESTILO', position: 'object-center' }
];
---

<section class="relative aspect-[4/3] sm:aspect-video md:aspect-auto md:h-[85vh] w-full overflow-hidden bg-black border-b-8 border-black">
  <div id="hero-slider" class="absolute inset-0 h-full w-full">
    {slides.map((slide, index) => (
      <div 
        class={`hero-slide absolute inset-0 h-full w-full opacity-0 transition-opacity duration-[2000ms] ease-in-out ${index === 0 ? 'active' : ''}`}
        data-index={index}
      >

        <Image 
          src={images[slide.url]()} 
          alt={slide.title}
          class={`h-full w-full object-cover ${slide.position}`}
          loading="eager"
        />
      </div>
    ))}
  </div>

  <!-- Controles Brutalistas -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-30 flex gap-4">
    {slides.map((_, i) => (
      <button 
        class={`w-12 h-2 border-2 border-black/50 transition-all duration-300 shadow-sm slider-dot ${i === 0 ? 'bg-white' : 'bg-transparent'}`}
        data-index={i}
        aria-label={`Ir a slide ${i + 1}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .hero-slide.active {
    opacity: 1;
    z-index: 10;
  }

  .hero-slide img {
    transform: scale(1.15);
    transition: transform 10s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .hero-slide.active img {
    transform: scale(1);
  }

  /* Textura de ruido aplicada al slider */
  #hero-slider::after {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.1;
    pointer-events: none;
    z-index: 15;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Cfilter id='noiseFilter'%3%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3%3C/filter%3%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3%3C/svg%3");
  }
</style>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.slider-dot');
  let current = 0;
  const interval = 4000;

  function nextSlide() {
    slides[current].classList.remove('active');
    dots[current].classList.remove('bg-white');
    dots[current].classList.add('bg-transparent');
    
    current = (current + 1) % slides.length;
    
    slides[current].classList.add('active');
    dots[current].classList.add('bg-white');
    dots[current].classList.remove('bg-transparent');
  }

  setInterval(nextSlide, interval);

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0');
      if (index === current) return;
      
      slides[current].classList.remove('active');
      dots[current].classList.remove('bg-white');
      dots[current].classList.add('bg-transparent');
      
      current = index;
      
      slides[current].classList.add('active');
      dots[current].classList.add('bg-white');
      dots[current].classList.remove('bg-transparent');
    });
  });
</script>
