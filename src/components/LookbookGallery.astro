---
// Lookbook gallery - editorial full-width
import { Image } from 'astro:assets';
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}');

interface Props {
  images?: { src: string; alt: string }[];
}

const defaultImages = [
  { src: '/src/assets/images/lookbook1.jpg', alt: 'TUC-HUMANO lookbook' }
];

const { images = defaultImages } = Astro.props;
---

<section id="lookbook" class="bg-celeste-500">
  <div class="py-14 text-center">
    <h2 class="text-4xl md:text-6xl font-display font-black text-black italic tracking-tighter leading-none uppercase">
      La remera en acción
    </h2>
    <p class="text-gray-900 mt-3 text-lg max-w-xl mx-auto font-technical font-medium">
      Donde la convicción pisa el asfalto, nuestra identidad no se queda en el ropero. Sale a la calle con orgullo, se hace cuerpo y se planta para el agite.
    </p>
  </div>

  <div class={`grid gap-1 ${images.length === 1 ? 'grid-cols-1' : 'grid-cols-1 md:grid-cols-2'}`}>
    {images.map((image) => (
      <a href="/producto/remera-oversize-de-lucha" class="lookbook-cell group block">
        <Image
          src={imagesGlob[image.src]()}
          alt={image.alt}
          loading="eager"
          class="w-full h-[60vh] md:h-[80vh] object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="lookbook-overlay">
          <span class="lookbook-label">TUC-HUMANO ✦</span>
        </div>
      </a>
    ))}
  </div>

  <!-- CTA -->
  <div class="text-center py-12">
    <a href="/tienda" class="btn-primary bg-black border-black hover:bg-white hover:text-black hover:border-white inline-flex transition-colors">
      Conseguí la tuya
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>

<style>
  .lookbook-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: auto;
    gap: 4px;
  }

  .lookbook-cell {
    overflow: hidden;
    position: relative;
    line-height: 0;
  }

  .lookbook-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lookbook-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 40%);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .group:hover .lookbook-overlay {
    opacity: 1;
  }

  .lookbook-label {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Mobile: 1 columna */
  @media (max-width: 640px) {
    .lookbook-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, 70vw);
    }
  }
</style>
